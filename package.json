{
  "name": "pdv-touch-restaurante",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node dev.mjs",
    "frontend:dev": "vite",
    "backend:dev": "tsx watch backend/src/server.ts",
    "backend:start": "tsx backend/src/server.ts",
    "start:prod": "tsx backend/src/server.ts",
    "build": "tsc -b && vite build",
    "electron:dev": "npm run build && electron electron/main.cjs",
    "electron:pack": "npm run build && electron-builder --win --x64",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "dexie": "^4.4.3",
    "express": "^5.2.1",
    "lucide-react": "^1.17.0",
    "pg": "^8.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "serialport": "^13.0.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^22.13.4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.9"
  },
  "build": {
    "appId": "br.com.pdvtouch.restaurante",
    "productName": "PDVTouch Restaurante",
    "directories": {
      "output": "release-electron"
    },
    "asar": false,
    "files": [
      "dist/**/*",
      "backend/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "artifactName": "PDVTouch-Restaurante-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "PDVTouch-Restaurante-Portable-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
